{
  "expo": {
    "name": "Sentinel",
    "slug": "Sentinel",
    "scheme": "com.fintrack.financeapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Sentinel_logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Sentinel_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.fintrack.financeapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Sentinel_logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
